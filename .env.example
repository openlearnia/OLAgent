# ASF LLM / agent runtime (M3+)

# Required for `asf server start` and internal API
ASF_INTERNAL_JWT_SECRET=dev-secret-change-me

# Local state directory
ASF_HOME=.asf-local

# --- LLM pilot (backend-engineer) ---
# Real provider: set API key and provider
# ASF_LLM_API_KEY=
# ASF_LLM_PROVIDER=anthropic
# ASF_LLM_MODEL=claude-sonnet-4-20250514

# Mock LLM (CI / local demo without API key)
# ASF_LLM_MOCK=1

# Comma-separated agent types that run live (default: backend-engineer)
# ASF_LLM_AGENT_TYPES=backend-engineer

# Subprocess agent mode: 1 = dry-run stub (M2), 0 = live pilot for allowlisted types
# ASF_AGENT_RUN_DRY_RUN=1

# In-process stub completion for full CRM CI (no subprocess)
# ASF_USE_STUB_AGENTS=1
