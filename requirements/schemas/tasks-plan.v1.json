{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asf.local/schemas/tasks-plan.v1.json",
  "title": "TasksPlan",
  "type": "object",
  "required": ["missionId", "tasks"],
  "properties": {
    "missionId": { "type": "string" },
    "version": { "type": "string", "default": "1.0" },
    "epics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" }
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/plannedTask" }
    }
  },
  "$defs": {
    "plannedTask": {
      "type": "object",
      "required": ["id", "type", "title", "assignedAgentType", "dependencies", "acceptanceCriteria"],
      "properties": {
        "id": { "type": "string", "pattern": "^t-[a-z0-9-]+$" },
        "epicId": { "type": ["string", "null"] },
        "type": {
          "type": "string",
          "enum": [
            "setup-repo", "schema-migration", "implement-backend", "implement-frontend",
            "implement-infra", "write-tests", "browser-test", "deploy", "verify-deployment"
          ]
        },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assignedAgentType": { "type": "string" },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "acceptanceCriteria": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "parallelSafe": { "type": "boolean", "default": false },
        "maxRetries": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
