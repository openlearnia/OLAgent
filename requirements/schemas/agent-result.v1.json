{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asf.local/schemas/agent-result.v1.json",
  "title": "AgentResult",
  "type": "object",
  "required": ["status", "artifacts", "commits", "summary"],
  "properties": {
    "status": { "type": "string", "enum": ["COMPLETED", "FAILED"] },
    "artifacts": { "type": "array", "items": { "type": "string" } },
    "commits": { "type": "array", "items": { "type": "string" } },
    "summary": { "type": "string" },
    "needsHealing": { "type": "boolean", "default": false },
    "error": {
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "recoverable": { "type": "boolean" },
        "classification": { "type": "string" }
      },
      "required": ["code", "message", "recoverable"]
    },
    "metrics": {
      "type": "object",
      "properties": {
        "tokenUsage": {
          "type": "object",
          "properties": {
            "input": { "type": "integer" },
            "output": { "type": "integer" }
          }
        },
        "durationMs": { "type": "integer" }
      }
    }
  }
}
